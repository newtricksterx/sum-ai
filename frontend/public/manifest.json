{
    "manifest_version": 3,
    "name": "__MSG_appName__",
    "description": "__MSG_appDescription__",
    "default_locale": "en",
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "version": "1.0.1",
    "action": {
        "default_title": "Open ReadToRecall",
        "default_popup": "index.html"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://readtorecall.com/*"
    ]
}
