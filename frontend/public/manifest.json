{
    "manifest_version": 3,
    "name": "Super Simple Summarizer",
    "icons": {
        "16": "sss_icon16.png",
        "32": "sss_icon32.png",
        "48": "sss_icon48.png",
        "128": "sss_icon128.png"
    },
    "version": "1.0.1",
    "action": {
        "default_popup": "index.html"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://super-summarizer.ddns.net/*"
    ]
}